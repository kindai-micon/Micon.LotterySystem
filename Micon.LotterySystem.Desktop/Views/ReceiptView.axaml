<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Micon.LotterySystem.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Micon.LotterySystem.Desktop.Views.ReceiptView"
             x:DataType="vm:ReceiptViewModel">

    <Design.DataContext>
        <vm:ReceiptViewModel/>
    </Design.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <TextBlock Grid.Row="0" Text="チケット印刷" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- 印刷フォーム -->
        <StackPanel Grid.Row="1" Spacing="15">
            <Grid ColumnDefinitions="Auto,*,Auto,*" Margin="0,0,0,10">
                <TextBlock Text="抽選会ID:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Text="{Binding LotteryGroupId}" Watermark="GUIDを入力"/>
                <TextBlock Grid.Column="2" Text="発行枚数:" VerticalAlignment="Center" Margin="20,0,10,0"/>
                <NumericUpDown Grid.Column="3" Value="{Binding TicketCount}" Minimum="1" Maximum="100"/>
            </Grid>

            <!-- ステータス選択 -->
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel Spacing="10">
                    <TextBlock Text="発行状態" FontWeight="Bold"/>

                    <Grid ColumnDefinitions="*,*" Margin="0,5,0,0">
                        <CheckBox Grid.Column="0" Content="有効状態で発行"
                                  IsChecked="{Binding ActivateOnIssue}"
                                  IsEnabled="{Binding !IsLoading}"/>

                        <CheckBox Grid.Column="1" Content="無効状態で発行"
                                  IsChecked="{Binding !ActivateOnIssue}"
                                  IsEnabled="{Binding !IsLoading}"/>
                    </Grid>

                    <TextBlock Text="{Binding StatusHint}" Foreground="Gray" FontSize="12" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- ボタン -->
            <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,10,0,0">
                <Button Content="クリア" Command="{Binding ClearTicketsCommand}"
                        IsEnabled="{Binding !IsLoading}" Padding="20,10" Grid.Column="1" Margin="0,0,10,0"/>
                <Button Content="印刷開始" Command="{Binding PrintTicketsCommand}"
                        IsEnabled="{Binding !IsLoading}" Padding="30,10" Background="#2196F3"
                        Foreground="White" FontWeight="Bold" Grid.Column="2"/>
            </Grid>
        </StackPanel>

        <!-- 進捗・ステータス表示 -->
        <StackPanel Grid.Row="2" Margin="0,15,0,0">
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="4" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsLoading}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#666"/>
                <TextBlock Foreground="#2196F3">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}/{1}">
                            <Binding Path="PrintProgress"/>
                            <Binding Path="PrintTotal"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}" Foreground="Gray"
                       IsVisible="{Binding !IsLoading}"/>
        </StackPanel>
    </Grid>

</UserControl>
